@model VasosInteligentes.Models.Planta

@{
	ViewData["Title"] = "Create";
}

<h1>Nova Planta</h1>

<hr />
<div class="row">
	<div class="col-md-4">
		<form asp-action="Create">
			<div asp-validation-summary="ModelOnly" class="text-danger"></div>
			<div class="form-group">
				<label asp-for="Nome" class="control-label"></label>
				<input asp-for="Nome" class="form-control" />
				<span asp-validation-for="Nome" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="UnidadeIdealMin" class="control-label"></label>
				<input asp-for="UnidadeIdealMin" class="form-control" />
				<span asp-validation-for="UnidadeIdealMin" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="UnidadeIdealMax" class="control-label"></label>
				<input asp-for="UnidadeIdealMax" class="form-control" />
				<span asp-validation-for="UnidadeIdealMax" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="LuminosidadeIdeal" class="control-label"></label>
				<input asp-for="LuminosidadeIdeal" class="form-control" />
				<span asp-validation-for="LuminosidadeIdeal" class="text-danger"></span>
			</div>
			<div class="form-group">
				<input type="submit" value="Create" class="btn btn-primary" />
				<a asp-action="Index">Back to List</a>
			</div>
		</form>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}
